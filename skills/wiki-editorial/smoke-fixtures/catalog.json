      "setup_steps": [
        {
          "action": "replace_text",
          "scope": "wiki_root",
          "path": "candidate/reports/manual-proposal.md",
          "old": "recommendation: pending",
          "new": "recommendation: approve"
        },
        {
          "action": "remove_regex",
          "scope": "wiki_root",
          "path": "candidate/patches/manual-proposal.md",
