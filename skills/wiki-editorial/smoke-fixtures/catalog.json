{
  "schema_version": 1,
  "batches": [
    {
      "id": "cli_guardrails",
      "label": "CLI guardrails",
      "scenario_ids": [
        "propose_help",
        "propose_missing_source",
        "propose_invalid_target_absolute",
        "propose_invalid_target_escape",
        "propose_invalid_target_noncanonical",
        "propose_max_two_targets",
        "propose_inference_fact_blocked"
      ]
    },
    {
      "id": "proposal_scaffolding",
      "label": "Proposal scaffolding",
      "scenario_ids": [
        "propose_happy_single_target",
        "propose_happy_two_targets",
        "propose_report_contract",
        "propose_patch_contract"
      ]
    },
    {
      "id": "publish_and_happy_path",
      "label": "Publish gating + happy path",
      "scenario_ids": [
        "publish_block_pending_recommendation",
        "publish_block_report_patch_target_mismatch",
        "publish_block_missing_target_block",
        "publish_block_placeholder_content",
        "publish_block_invalid_frontmatter",
        "publish_block_broken_source_ref",
        "publish_block_invalid_contradicts_supersedes",
        "publish_block_broken_local_link",
        "publish_new_page",
        "publish_replace_existing_page",
        "publish_local_scope_neighbors",
        "publish_no_repo_mutation"
      ]
    },
    {
      "id": "lint_and_integration",
      "label": "Full lint + integration",
      "scenario_ids": [
        "full_lint_duplicate_title_warns",
        "full_lint_orphan_warns",
        "full_lint_stale_review_warns",
        "full_lint_high_confidence_weak_provenance_warns",
        "full_lint_superseded_warns",
        "hook_lists_skill_only",
        "real_root_full_lint_empty_ok",
        "skill_doc_examples_still_match_cli"
      ]
    }
  ],
  "scenarios": [
    {
      "id": "propose_help",
      "batch": "cli_guardrails",
      "gate": "must-pass",
      "description": "Subcommand help renders cleanly.",
      "command": ["python3", "{cli_path}", "propose", "--help"],
      "expected_exit": "success",
      "expected_stdout": [
        "--target-path TARGET_PATH"
      ]
    },
    {
      "id": "propose_missing_source",
      "batch": "cli_guardrails",
      "gate": "must-pass",
      "description": "Missing source file blocks propose.",
      "command": [
        "python3",
        "{cli_path}",
        "--wiki-root",
        "{wiki_root}",
        "propose",
        "--title",
        "Missing Source",
        "--domain",
        "preferences",
        "--status",
        "fact",
        "--review-basis",
        "explicit_source",
        "--source",
        "{workspace_root}/missing.md",
        "--target-path",
        "canonical/preferences/missing-source.md"
      ],
      "expected_exit": "blocked",
      "expected_stderr": [
        "Source file not found"
      ]
    },
    {
      "id": "propose_invalid_target_absolute",
      "batch": "cli_guardrails",
      "gate": "must-pass",
      "description": "Absolute target path is rejected.",
      "setup_steps": [
        {
          "action": "copy_file",
          "from": "common/source-note.md",
          "to_scope": "workspace_root",
          "to": "source-note.md"
        }
      ],
      "command": [
        "python3",
        "{cli_path}",
        "--wiki-root",
        "{wiki_root}",
        "propose",
        "--title",
        "Absolute Target",
        "--domain",
        "preferences",
        "--status",
        "fact",
        "--review-basis",
        "explicit_source",
        "--source",
        "{workspace_root}/source-note.md",
        "--target-path",
        "/tmp/absolute-target.md"
      ],
      "expected_exit": "blocked",
      "expected_stderr": [
        "Target path must be relative to knowledge-wiki"
      ]
    },
    {
      "id": "propose_invalid_target_escape",
