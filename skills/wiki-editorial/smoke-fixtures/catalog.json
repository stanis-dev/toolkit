    {
      "id": "propose_happy_single_target",
      "batch": "proposal_scaffolding",
      "gate": "must-pass",
      "description": "Single-target propose scaffolds raw, report, patch, and manifest without touching canonical.",
      "setup_steps": [
        {
          "action": "copy_file",
          "from": "common/source-note.md",
          "to_scope": "workspace_root",
          "to": "source-note.md"
        }
      ],
      "captures": [
        {
          "source": "stdout",
          "name": "proposal_id",
          "pattern": "^proposal_id: (?P<value>[A-Za-z0-9-]+)$"
        }
      ],
      "command": [
        "python3",
        "{cli_path}",
        "--wiki-root",
        "{wiki_root}",
        "propose",
        "--title",
        "Communication Style Preference",
        "--domain",
        "preferences",
        "--status",
        "fact",
        "--review-basis",
        "explicit_source",
        "--source",
        "{workspace_root}/source-note.md",
        "--target-path",
        "canonical/preferences/communication-style.md"
      ],
      "expected_exit": "success",
      "expected_stdout": [
        "proposal_id: {proposal_id}",
        "raw_dir: raw/ingest/{proposal_id}",
        "report: candidate/reports/{proposal_id}.md",
        "patch: candidate/patches/{proposal_id}.md"
      ],
      "expected_files": [
        {
          "scope": "wiki_root",
          "path": "raw/ingest/{proposal_id}/source-01-source-note.md",
          "type": "file",
          "contains": ["direct answers and explicit pushback"]
        },
        {
          "scope": "wiki_root",
          "path": "raw/ingest/{proposal_id}/manifest.json",
          "type": "file",
          "contains": ["\"proposal_id\": \"{proposal_id}\"", "\"copied_path\": \"raw/ingest/{proposal_id}/source-01-source-note.md\""]
        },
        {
          "scope": "wiki_root",
          "path": "candidate/reports/{proposal_id}.md",
          "type": "file",
          "contains": ["recommendation: pending", "## Why this deserves canon", "## Publication recommendation"]
        },
        {
          "scope": "wiki_root",
          "path": "candidate/patches/{proposal_id}.md",
          "type": "file",
          "contains": ["## Target: canonical/preferences/communication-style.md", "title: Communication Style"]
        },
        {
          "assertion": "glob_count",
          "scope": "wiki_root",
          "glob": "canonical/**/*.md",
          "count": 0
        }
      ]
    },
    {
      "id": "propose_happy_two_targets",
